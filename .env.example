# ── Домен и порт ──────────────────────────────────
DOMAIN=ca.internal.example.com
STEP_CA_PORT=8443

# ── CA Identity ───────────────────────────────────
STEP_CA_NAME="Internal SSH CA"
STEP_CA_DNS=${DOMAIN},localhost,step-ca

# ── Пароли ────────────────────────────────────────
STEP_CA_PASSWORD=CHANGE_ME_CA_PASSWORD
STEP_PROVISIONER_NAME=admin
STEP_PROVISIONER_PASSWORD=CHANGE_ME_PROVISIONER_PASSWORD

# ── PostgreSQL ────────────────────────────────────
POSTGRES_DB=stepca
POSTGRES_USER=stepca
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_PORT=5432
